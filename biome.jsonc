{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"files": {
		"includes": [
			"**",
			// Agent worktrees are nested repo checkouts (own biome root) under
			// `.claude/worktrees/`; exclude only those, not the rest of `.claude`,
			// so the repo's own skill/config files still get linted (#119).
			"!**/.claude/worktrees",
			// Workflow scripts (`.claude/workflows/*.js`) use the Workflow runtime
			// contract — top-level `return` + `export const meta` — which biome
			// can't parse as a standard module; you can't format/lint what won't
			// parse, so exclude them (same precedent as `!biome-plugins`).
			"!**/.claude/workflows",
			// The GritQL plugin source: biome's `.grit` formatter drops the
			// `language js;` terminator, which silently breaks the plugin.
			"!biome-plugins",
			// Vendored, version-pinned third-party builds (e.g. the rite-audit
			// accessibility dimension's `axe.min.js`, MPL-2.0) are not ours to
			// format/lint — touching them breaks the pin + the license banner.
			"!**/rite-audit/dimensions/vendor",
			"!**/worker-configuration.d.ts",
			"!**/__generated__",
			"!**/dist",
			"!**/drizzle/migrations",
			"!**/schema.graphql"
		]
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 100,
		"indentStyle": "tab"
	},
	"plugins": [
		"./biome-plugins/no-type-assertions.grit",
		"./biome-plugins/no-node-sqlite-test-backing.grit"
	],
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"bracketSpacing": false
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	},
	"overrides": [
		{
			"includes": ["**/tests/**", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	]
}
