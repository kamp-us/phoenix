{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		// `composite` mirrors the worker project (`apps/web/tsconfig.worker.json`),
		// the package's first real consumer: composite makes tsgo run the
		// declaration-nameability checks (TS2883), the permanent guard that every
		// exported surface — the `FateDataView` factory above all — stays portably
		// nameable. A non-composite `noEmit` check would pass that gate vacuously.
		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
		"noEmit": true,
		// The package ships TS source (`exports` → `./src/index.ts`); consumers
		// bundle it. Repo style imports with explicit `.ts` specifiers.
		"allowImportingTsExtensions": true,
		"types": ["node"]
	},
	"include": ["src", "vitest.config.ts"]
}
