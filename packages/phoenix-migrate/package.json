{
	"name": "@kampus-phoenix/phoenix-migrate",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"phoenix-migrate": "./src/bin.ts"
	},
	"scripts": {
		"phoenix-migrate": "node --experimental-strip-types ./src/bin.ts",
		"typecheck": "tsgo --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@effect/platform-node": "catalog:",
		"effect": "catalog:"
	},
	"devDependencies": {
		"@effect/tsgo": "catalog:",
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
