# Local dev environment for `alchemy dev`.
#
# Copy this file to `.env` (gitignored): `cp .env.example .env`
# `alchemy dev` auto-loads `.env` from this directory, so `pnpm alchemy dev`,
# `pnpm dev:worker`, and `pnpm dev` all boot with these set.
#
# These are DEV-INSECURE placeholders. Production `BETTER_AUTH_SECRET` is a
# Cloudflare `secret_text` binding set by `alchemy deploy` — never read from here.

ENVIRONMENT=development
BETTER_AUTH_SECRET=dev-insecure-better-auth-secret
