# Local dev environment for `alchemy dev`.
#
# Copy this file to `.env` (gitignored): `cp .env.example .env`
# `alchemy dev` auto-loads `.env` from this directory, so `pnpm alchemy dev`,
# `pnpm dev:worker`, and `pnpm dev` all boot with these set.
#
# Throwaway DEV secrets — never production. `BETTER_AUTH_SECRET` is an
# `insecure_`-prefixed 32-byte hex value: self-labelled as not-a-real-secret, but
# long + high-entropy enough that better-auth's startup length/entropy checks stay
# quiet in dev and the test deploy. Production
# `BETTER_AUTH_SECRET` is a Cloudflare `secret_text` binding set by `alchemy
# deploy` — never read from here.

ENVIRONMENT=development
BETTER_AUTH_SECRET=insecure_f0fe1c4259c35ad24020049fc1c52b8639eae5d22aaf2a6b48101e8b47d37ede
