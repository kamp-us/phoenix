{
	"name": "@phoenix/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"cf:deploy": "pnpm build && wrangler deploy --env production",
		"cf:deploy:staging": "pnpm build && wrangler deploy --env staging",
		"cf:deploy:test": "pnpm build && wrangler deploy --env test",
		"typecheck": "pnpm fate:generate && tsgo -b tsconfig.worker.json tsconfig.node.json && tsgo -p tsconfig.app.json --composite false",
		"test": "vitest run --config vitest.config.ts",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install chromium",
		"cf-typegen": "wrangler types",
		"fate:generate": "fate generate",
		"sozluk:import": "node --experimental-strip-types scripts/import-sozluk.ts",
		"pano:import": "node --experimental-strip-types scripts/import-pano.ts"
	},
	"dependencies": {
		"@base-ui/react": "catalog:",
		"@better-auth/core": "catalog:",
		"@nkzw/fate": "catalog:",
		"@usirin/forge": "catalog:",
		"agents": "catalog:",
		"better-auth": "catalog:",
		"better-call": "catalog:",
		"drizzle-orm": "catalog:",
		"effect": "catalog:",
		"hono": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-fate": "catalog:",
		"react-router": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "catalog:",
		"@cloudflare/vitest-pool-workers": "catalog:",
		"@cloudflare/workers-types": "catalog:",
		"@effect/tsgo": "catalog:",
		"@effect/vitest": "catalog:",
		"@playwright/test": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@typescript/native-preview": "catalog:",
		"@vitejs/plugin-react-swc": "catalog:",
		"drizzle-kit": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:",
		"wrangler": "catalog:"
	}
}
