{
	"name": "@phoenix/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "pnpm build && wrangler deploy",
		"typecheck": "tsgo -b",
		"test": "vitest run --config vitest.config.ts",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install chromium",
		"cf-typegen": "wrangler types",
		"relay": "mkdir -p src/__generated__ && relay-compiler",
		"relay:watch": "mkdir -p src/__generated__ && relay-compiler --watch",
		"schema:fetch": "curl -sf http://localhost:3000/graphql/schema -o schema.graphql",
		"sozluk:import": "node --experimental-strip-types scripts/import-sozluk.ts",
		"pano:import": "node --experimental-strip-types scripts/import-pano.ts"
	},
	"dependencies": {
		"@base-ui/react": "catalog:",
		"@better-auth/core": "catalog:",
		"@usirin/forge": "catalog:",
		"agents": "catalog:",
		"better-auth": "catalog:",
		"better-call": "catalog:",
		"drizzle-orm": "catalog:",
		"effect": "catalog:",
		"graphql": "catalog:",
		"graphql-yoga": "catalog:",
		"hono": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-relay": "catalog:",
		"react-router": "catalog:",
		"relay-runtime": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "catalog:",
		"@cloudflare/vitest-pool-workers": "catalog:",
		"@cloudflare/workers-types": "catalog:",
		"@effect/tsgo": "catalog:",
		"@effect/vitest": "catalog:",
		"@playwright/test": "catalog:",
		"@swc/plugin-relay": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@types/react-relay": "catalog:",
		"@types/relay-runtime": "catalog:",
		"@typescript/native-preview": "catalog:",
		"@vitejs/plugin-react-swc": "catalog:",
		"drizzle-kit": "catalog:",
		"relay-compiler": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:",
		"wrangler": "catalog:"
	}
}
