{
	"name": "@phoenix/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:worker": "ENVIRONMENT=development alchemy dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "pnpm build && alchemy deploy",
		"destroy": "alchemy destroy",
		"typecheck": "pnpm fate:generate && tsgo -b tsconfig.worker.json tsconfig.node.json && tsgo -p tsconfig.app.json --composite false",
		"test": "vitest run --config vitest.config.ts",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install chromium",
		"fate:generate": "fate generate",
		"sozluk:import": "node --experimental-strip-types scripts/import-sozluk.ts",
		"pano:import": "node --experimental-strip-types scripts/import-pano.ts"
	},
	"dependencies": {
		"@alchemy.run/better-auth": "catalog:",
		"@base-ui/react": "catalog:",
		"@better-auth/core": "catalog:",
		"@effect/platform-bun": "catalog:",
		"@effect/platform-node": "catalog:",
		"@effect/sql-pg": "catalog:",
		"@effect/sql-sqlite-do": "catalog:",
		"@nkzw/fate": "catalog:",
		"@usirin/forge": "catalog:",
		"alchemy": "catalog:",
		"better-auth": "catalog:",
		"better-call": "catalog:",
		"drizzle-orm": "catalog:",
		"effect": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-fate": "catalog:",
		"react-router": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:",
		"@effect/tsgo": "catalog:",
		"@effect/vitest": "catalog:",
		"@playwright/test": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@typescript/native-preview": "catalog:",
		"@vitejs/plugin-react-swc": "catalog:",
		"drizzle-kit": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
